{
  "name": "ai-economy-ledger",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source accounting for the AI economy.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=22 <25"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "prepare": "node scripts/setup-git-hooks.mjs",
    "setup": "node scripts/setup-git-hooks.mjs",
    "dev": "next dev",
    "lint": "node scripts/ci/run-lint.mjs",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "generate:data-release": "node scripts/data/generate-pr34-release-module.mjs",
    "generate:analytics": "node scripts/data/generate-pr37-analytics-module.mjs",
    "validate:data": "node scripts/ci/validate-data.mjs",
    "build": "next build",
    "build:cloudflare": "opennextjs-cloudflare build && node scripts/ci/sanitize-opennext-env.mjs && node scripts/ci/scan-opennext-output.mjs",
    "preview": "pnpm build:cloudflare && opennextjs-cloudflare preview",
    "deploy": "pnpm build:cloudflare && opennextjs-cloudflare deploy",
    "upload": "pnpm build:cloudflare && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:test": "supabase test db",
    "db:lint": "supabase db lint --local --level warning --fail-on warning",
    "admin:bootstrap": "node scripts/admin/bootstrap-admin.mjs",
    "admin:rls-smoke": "node scripts/admin/rls-smoke.mjs",
    "test:cloudflare-preview": "node scripts/ci/cloudflare-preview-smoke.mjs",
    "verify": "node scripts/ci/run-verify.mjs"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "postgres": "3.4.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@tailwindcss/postcss": "4.3.3",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.20",
    "rclone.js": "0.6.6",
    "supabase": "2.109.1",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "wrangler": "4.112.0"
  }
}
